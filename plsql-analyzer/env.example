# PL/SQL Analyzer — Oracle connection credentials template
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore.

# Required: Oracle connection
ORACLE_USER=your_db_username
ORACLE_PASSWORD=your_db_password
ORACLE_CONNECT_STRING=hostname:1521/SERVICE_NAME

# Optional: Oracle Wallet (alternative to user/password)
# ORACLE_WALLET_DIR=/path/to/wallet
# TNS_ADMIN=/path/to/tns/admin

# Optional: Named connection profile to activate
# ORACLE_PROFILE=dev

# Optional: External secret managers (URL/path only — no secrets here)
# VAULT_ADDR=https://vault.example.com
# VAULT_SECRET_PATH=secret/data/oracle/dev
# AZURE_KEYVAULT_URI=https://myvault.vault.azure.net
# AZURE_KEYVAULT_SECRET_NAME=oracle-dev-credentials
# AWS_SECRETS_MANAGER_REGION=us-east-1
# AWS_SECRETS_MANAGER_ARN=arn:aws:secretsmanager:us-east-1:123456789:secret:oracle-dev
